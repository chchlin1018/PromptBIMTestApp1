# PromptBIMTestApp1 Configuration
# Copy to .env and fill in your values

# === Required ===
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# === Optional ===
# F3D binary path (for offscreen rendering)
F3D_PATH=f3d

# Output directory
OUTPUT_DIR=./output

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Default city for seismic/zoning lookup
DEFAULT_CITY=台北市

# Claude model
CLAUDE_MODEL=claude-sonnet-4-20250514
